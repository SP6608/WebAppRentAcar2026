@using WebAppRentAcar.ViewModels
@model CarDetailsViewModel

@{
    ViewData["Title"] = "Car Details";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header">
            <h2 class="mb-0">@Model.Brand @Model.Model</h2>
        </div>

        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Brand</dt>
                <dd class="col-sm-9">@Model.Brand</dd>

                <dt class="col-sm-3">Model</dt>
                <dd class="col-sm-9">@Model.Model</dd>

                <dt class="col-sm-3">Year</dt>
                <dd class="col-sm-9">@Model.Year</dd>

                <dt class="col-sm-3">Passengers</dt>
                <dd class="col-sm-9">@Model.Passengers</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        @Model.Description
                    }
                    else
                    {
                        <span class="text-muted">No description available.</span>
                    }
                </dd>

                <dt class="col-sm-3">Price per day</dt>
                <dd class="col-sm-9">@Model.PricePerDay.ToString("F2") lv.</dd>
            </dl>
        </div>

        <div class="card-footer d-flex justify-content-between">
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                Back to List
            </a>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a asp-controller="Reservations" asp-action="Create" asp-route-carId="@Model.Id" class="btn btn-primary">
                    Reserve
                </a>
            }
        </div>
    </div>
</div>