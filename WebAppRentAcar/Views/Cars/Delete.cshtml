@model CarsDeleteViewModel

@{
    ViewData["Title"] = "Delete Car";
}

<h2 class="mb-4">Delete Car</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this car?
</div>

<div class="card">
    <div class="card-body">
        <h5>@Model.Brand @Model.Model</h5>
        <p><strong>Year:</strong> @Model.Year</p>
        <p><strong>Passengers:</strong> @Model.Passengers</p>
        <p><strong>Price per day:</strong> @Model.PricePerDay</p>
        <p><strong>Description:</strong> @Model.Description</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>