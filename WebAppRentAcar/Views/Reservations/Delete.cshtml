@model WebAppRentAcar.ViewModels.ReservationDeleteViewModel

@{
    ViewData["Title"] = "Delete Reservation";
}

<h2 class="mb-4">Delete Reservation</h2>

<div class="alert alert-warning">
    Are you sure you want to delete this reservation?
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Car:</strong> @Model.CarName</p>
        <p><strong>Start date:</strong> @Model.StartDate.ToString("dd.MM.yyyy")</p>
        <p><strong>End date:</strong> @Model.EndDate.ToString("dd.MM.yyyy")</p>
        <p>
            <strong>Status:</strong>
            @(Model.IsApproved ? "Approved" : "Pending")
        </p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>